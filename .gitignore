# Root .gitignore for multi-project Docker deployment

# ============================================================================
# 敏感文件：.env（生产环境变量，不提交到 Git）
# ============================================================================
**/.env
**/.env.local
**/.env.production

# ============================================================================
# Node.js
# ============================================================================
**/node_modules/
**/.pnpm/
**/pnpm-lock.yaml

# ============================================================================
# Build artifacts
# ============================================================================
**/.next/
**/dist/
**/build/
**/out/
/**/.vercel/

# ============================================================================
# TypeScript
# ============================================================================
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# IDE & Editor
# ============================================================================
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
*~

# ============================================================================
# Logging
# ============================================================================
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# ============================================================================
# Docker
# ============================================================================
**/.dockerx/
**/docker-cache/

# ============================================================================
# Nginx
# ============================================================================
shared/nginx/logs/
shared/nginx/ssl/live/
shared/nginx/ssl/archive/
shared/nginx/ssl/renewal/

# ============================================================================
# OS files
# ============================================================================
.DS_Store
*.pem
Thumbs.db

# ============================================================================
# Testing/Temp
# ============================================================================
**/coverage/
**/.nyc_output/
**/tmp/
**/temp/
