# Production environment example for ai-research-app
# Copy to .env.production and fill values before deploying

# Application
APP_PORT=3000
APP_TAG=latest
IMAGE=myorg/ai-research-app
NODE_ENV=production

# MongoDB (used by Prisma)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme
# Prisma DB URL (模板)：替换用户名/密码/域名
# 例: mongodb://admin:changeme@mongodb:27017/ai_research?authSource=admin&replicaSet=rs0
DATABASE_URL="mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:27017/ai_research?authSource=admin&replicaSet=rs0"

# Authentication / secrets
AUTH_SECRET=please_change_this_to_a_strong_secret
NEXTAUTH_URL=https://your.domain

# Optional public keys for Next.js
NEXT_PUBLIC_EXAMPLE_KEY=
