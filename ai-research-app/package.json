{
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev -H localhost",
    "dev:full": "pnpm run db:start && pnpm run db:push && pnpm run dev",
    "db:start": "pgrep -x mongod > /dev/null || (mongod --replSet rs0 --dbpath /usr/local/var/mongodb --logpath /usr/local/var/log/mongodb/mongo.log & sleep 2)",
    "db:push": "DATABASE_URL=\"mongodb://localhost:27017/ai_research?replicaSet=rs0&directConnection=true\" npx prisma db push",
    "db:stop": "mongosh --eval 'db.adminCommand({shutdown:1})' --quiet || true",
    "start": "next start"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "10.4.20",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "next": "latest",
    "next-auth": "5.0.0-beta.25",
    "openai": "^6.34.0",
    "postcss": "8.5.1",
    "postgres": "^3.4.6",
    "prisma": "^6.19.3",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "use-debounce": "^10.0.4",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  }
}
