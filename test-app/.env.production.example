# ============================================================================
# 环境变量模板 - 从这里复制到 .env 并填写真实值
# ============================================================================

# 项目标识（多项目部署时必须唯一）
PROJECT_NAME=test-app

# 应用端口（多项目时避免冲突，如：3001, 3002, 3003...）
APP_PORT=3002

# ============================================================================
# MongoDB 配置
# ============================================================================

# MongoDB 认证信息（安全加固）
MONGO_USER=admin
MONGO_PASSWORD=your-secure-password-here

# MongoDB 数据库 URL（自动依赖 PROJECT_NAME）
DATABASE_URL="mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb-${PROJECT_NAME}:27017/ai_research?replicaSet=rs0&authSource=admin&directConnection=true"

# ============================================================================
# AI API Keys（第三方服务）
# ============================================================================

# DeepSeek API
DEEPSEEK_API_KEY=sk_...your_deepseek_api_key_here...

# Serper API（Google 搜索）
SERPER_API_KEY=...your_serper_api_key_here...

# ============================================================================
# NextAuth 安全配置
# ============================================================================
AUTH_SECRET=...your_generated_auth_secret_here...
